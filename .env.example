# Groq (transcription via Whisper) — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# Google Gemini (viral moment detection) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Optional model overrides
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo   # or whisper-large-v3
# GEMINI_MODEL=gemini-3.5-flash

# Keeps Docker container names stable (autoclipper-backend / -frontend)
COMPOSE_PROJECT_NAME=autoclipper

# --- Auth (user accounts + per-user API keys) ---
# Secret used to sign JWTs AND to encrypt stored API keys at rest.
# CHANGE THIS to a long random string in production.
AUTOCLIPPER_SECRET=change-me-to-a-long-random-string
# Token lifetime in minutes (default 1440 = 24h)
# AUTOCLIPPER_TOKEN_MINUTES=1440
# Path to the SQLite user database (optional)
# AUTOCLIPPER_DB=autoclipper.db

# --- Voice-over (Kokoro TTS local model cache) ---
# Where the Kokoro ONNX model is cached (Docker volume by default).
# KOKORO_CACHE=/app/models/kokoro

# YouTube cookies (optional — paste Netscape-format cookies to bypass bot detection)
# YOUTUBE_COOKIES=...

# Groq audio upload limit in MB (free tier 25, dev tier 100). Audio is chunked below this.
# GROQ_MAX_AUDIO_MB=24

# Burned-in subtitle styling (optional)
# SUBTITLE_FONT=Arial
# SUBTITLE_FONT_SIZE=80
# SUBTITLE_WORDS_PER_CUE=1          # words shown per caption (1 = word-by-word)
# SUBTITLE_MARGIN_V=120
